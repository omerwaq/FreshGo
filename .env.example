# ─── Groq AI (free LLM) ──────────────────────────────────────────────────────
# Get from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─── Facebook ─────────────────────────────────────────────────────────────────
# Get from https://developers.facebook.com → Your App → Messenger → Settings
FACEBOOK_PAGE_ID=your_page_id_here
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token_here
WEBHOOK_VERIFY_TOKEN=freshgo_secret_123

# Your personal Facebook user ID (admin mode trigger)
ADMIN_FB_ID=your_facebook_user_id_here

# ─── Instagram ────────────────────────────────────────────────────────────────
# Instagram Business Account ID linked to your Facebook Page
# Find at: Graph API Explorer → GET /me/accounts → find your page → instagram_business_account
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here

# ─── WhatsApp Business (Meta Cloud API) ──────────────────────────────────────
# Get from: Meta Business Manager → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_VERIFY_TOKEN=freshgo_wa_secret

# ─── Admin Notifications ──────────────────────────────────────────────────────
# WhatsApp number to receive new-order alerts (include country code, e.g. 923001234567)
ADMIN_WHATSAPP_PHONE=923001234567

# ─── Server ───────────────────────────────────────────────────────────────────
# Public URL where this server is hosted (for Instagram media URLs + notifications)
# For local dev with ngrok: https://abc123.ngrok.io
# For production: https://freshgo.yourdomain.com
BASE_URL=http://localhost:8000
